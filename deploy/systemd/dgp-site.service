[Unit]
Description=DGP Site (Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/dgp-site
EnvironmentFile=/opt/dgp-site/.env
ExecStart=/opt/dgp-site/.venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 --timeout 120 --access-logfile - --error-logfile - wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
